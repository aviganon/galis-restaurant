# Firebase — פרויקט המערכת החדשה (Restaurant Pro)
# העתק קובץ זה ל-.env.local והזן את הערכים מהפרויקט החדש ב-Firebase Console

NEXT_PUBLIC_FIREBASE_API_KEY=
# בפרודקשן עם דומיין מותאם (למשל galis.app) — ודא שב-Firebase Console יש את הדומיין ב-Authorized domains;
# הקוד מגדיר authDomain לפי window.location כשהאתר ב-galis.app (חשוב ל-Google ב-Safari).
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- אימיילים (הזמנות + «שכחתי סיסמה») + Admin בשרת ---
# מדריך מלא: CLAUDE-איפוס-סיסמה-ומיילים.md
# חובה לפרודקשן אם רוצים מייל איפוס אמין: RESEND_API_KEY + FIREBASE_SERVICE_ACCOUNT_JSON + NEXT_PUBLIC_APP_URL
# Resend: https://resend.com — אימות דומיין ל-RESEND_FROM_EMAIL
RESEND_API_KEY=
RESEND_FROM_EMAIL=Restaurant Pro <onboarding@resend.dev>
NEXT_PUBLIC_APP_URL=https://your-app.web.app

# JSON מלא של Service Account (שורה אחת) — גם לאיפוס במייל (generatePasswordResetLink) וגם להגדרת סיסמה ע״י בעל מערכת
# Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON=
