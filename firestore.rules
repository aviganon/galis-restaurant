rules_version = '2';

// Restaurant Pro — מערכת חדשה (פרויקט Firebase נפרד)
// Collections: config, users, restaurants, inviteCodes, ingredients, invoiceLog

service cloud.firestore {
  match /databases/{database}/documents {

    // helper: האם המשתמש ב־config/admins (בעלים/מנהל מערכת)
    function isConfigAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/config/admins)
        && request.auth.token.email in get(/databases/$(database)/documents/config/admins).data.emails;
    }

    // כמו ב־app/page: משתמש עם users/{uid}.isSystemOwner == true — ניהול כל המסעדות גם בלי רשימת admins
    function isSystemOwnerUser() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSystemOwner == true;
    }

    function canManageAllRestaurants() {
      return isConfigAdmin() || isSystemOwnerUser();
    }

    // config — admins / adminEmails: קריאה לכל מחובר (זיהוי בעלים באפליקציה); כתיבה רק לבעל מערכת או אדמין
    match /config/admins {
      allow read: if request.auth != null;
      allow write: if canManageAllRestaurants();
    }
    match /config/adminEmails {
      allow read: if request.auth != null;
      allow write: if canManageAllRestaurants();
    }
    // מפתח Claude גלובלי — רק בעל מערכת / אדמין (שאר המשתמשים: מפתח מקומי או /api/claude עם env)
    match /config/anthropic {
      allow read, write: if canManageAllRestaurants();
    }

    // users — משתמשים לפי uid
    // list: בעל מערכת / אדמין — כל המשתמשים; אחרת — רק באותה מסעדה (restaurantId)
    // update: מנהל יכול לעדכן הרשאות של משתמשים באותה מסעדה
    match /users/{userId} {
      allow get: if request.auth != null && (
        request.auth.uid == userId
        || isConfigAdmin()
        || isSystemOwnerUser()
        || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.restaurantId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId)
      );
      allow list: if request.auth != null && (
        isConfigAdmin()
        || isSystemOwnerUser()
        || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.restaurantId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId)
      );
      // create: רישום עצמי (uid = מזהה המסמך), או בעל מערכת — יצירת משתמש משני (Auth) + setDoc עם הטוקן של המחובר הראשי
      allow create: if request.auth != null && (
        request.auth.uid == userId
        || isConfigAdmin()
        || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['manager', 'admin']
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId != null
          && request.resource.data.restaurantId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId
          && request.resource.data.role in ['manager', 'user']
          && request.resource.data.isSystemOwner != true
        )
      );
      allow update: if request.auth != null && (
        request.auth.uid == userId
        || isConfigAdmin()
        || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.restaurantId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['manager', 'admin'])
      );
      allow delete: if request.auth != null && (
        request.auth.uid == userId
        || canManageAllRestaurants()
        || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['manager', 'admin']
          && resource.data.restaurantId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId
          && resource.data.isSystemOwner != true
        )
      );
    }

    // restaurants — מסעדות (get מותר ללא auth — לאימות בהרשמה עם קוד קיים)
    match /restaurants/{restaurantId} {
      allow get: if true;
      allow list, create, update, delete: if request.auth != null;

      // appState — invitedEmails וכו' (משתמש מוזמן יכול לקרוא אם האימייל שלו ברשימה)
      // inboundSettings — רק בעל מערכת/אדמין (כתובת ייבוא); שאר appState — גם מנהל/משתמש במסעדה
      match /appState/{docId} {
        allow read: if request.auth != null && (
          canManageAllRestaurants()
          || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId == restaurantId)
          || (docId == 'invitedEmails' && request.auth.token.email in resource.data.get('list', []))
        );
        allow write: if request.auth != null && (
          canManageAllRestaurants()
          || (
            docId != 'inboundSettings'
            && exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId == restaurantId
          )
        );
      }

      // Subcollections: recipes, ingredients — רק לבעלים/מנהל/משתמש של המסעדה
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && (canManageAllRestaurants() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId == restaurantId));
      }
    }

    // inviteCodes — קודי הזמנה (get מותר גם ללא התחברות — לאימות בהרשמה)
    match /inviteCodes/{codeId} {
      allow get: if true;
      allow list, create, update, delete: if request.auth != null;
    }

    // ingredients — רכיבים גלובליים
    match /ingredients/{docId} {
      allow read, write: if request.auth != null;
      // prices — מחירים מכמה ספקים (להשוואת מחירים)
      match /prices/{priceId} {
        allow read, write: if request.auth != null;
      }
    }

    // suppliers — ספקים גלובליים (פאנל מנהל)
    match /suppliers/{docId} {
      allow read, write: if request.auth != null;
    }

    // invoiceLog — לוג חשבוניות
    match /invoiceLog/{docId} {
      allow read, write: if request.auth != null;
    }

    // webPriceCache — מטמון מחירי אינטרנט לרכיבים (חוסך בדיקות API)
    match /webPriceCache/{docId} {
      allow read, write: if request.auth != null;
    }

    // purchaseOrders — הזמנות ספקים (לפי restaurantId) — מסעדה: רק של עצמם; בעל מערכת/אדמין: הכל (גם getDocs ללא פילטר בפאנל)
    match /purchaseOrders/{docId} {
      allow read, update, delete: if request.auth != null && (
        canManageAllRestaurants()
        || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.restaurantId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId)
      );
      allow create: if request.auth != null && (
        canManageAllRestaurants()
        || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && request.resource.data.restaurantId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId)
      );
    }

    // inboundJobs — תור קבצים שהגיעו ממייל (כתיבה בדרך כלל מ-Cloud Function)
    match /inboundJobs/{jobId} {
      allow read: if request.auth != null && (
        isConfigAdmin()
        || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.restaurantId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId)
      );
      // לקליינט מותר לעדכן רק status בלבד, ורק למסעדה שלו.
      allow update: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && resource.data.restaurantId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status"])
        && request.resource.data.status in ["pending", "processing", "done", "error"];
      allow create, delete: if false;
    }

    // inbound email lookup — token → restaurantId (מייל נכנס)
    // קריאה: בעל מערכת / מסמך לא קיים / מזהה של המסעדה שלי — או **כל משתמש עם restaurantId**
    // (נדרש כדי לבדוק אם slug תפוס על ידי מסעדה *אחרת* — «הצע לפי שם», בדיקת זמינות).
    match /inboundEmailLookup/{token} {
      allow read: if request.auth != null && (
        canManageAllRestaurants()
        || resource == null
        || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && resource.data.restaurantId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId)
        || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId != null)
      );
      allow create, update: if request.auth != null && canManageAllRestaurants();
      allow delete: if request.auth != null && canManageAllRestaurants();
    }

    // בקשות מצוות מסעדה לשינוי כתובת ייבוא — יוצרים חברי צוות, רואים ומוחקים רק בעל מערכת/אדמין
    match /inboundChangeRequests/{requestId} {
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId == request.resource.data.restaurantId
        && request.resource.data.restaurantId is string
        && request.resource.data.message is string
        && request.resource.data.requestedByUid is string
        && request.resource.data.createdAt is string;
      allow read, delete: if canManageAllRestaurants();
      allow update: if false;
    }
  }
}
