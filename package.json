{
  "name": "my-project",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.0.0",
  "scripts": {
    "migrate:ingredients": "npx tsx scripts/migrate-ingredients.ts",
    "migrate:ingredients:admin": "node scripts/migrate-ingredients-admin.mjs",
    "add:admin": "npx tsx scripts/add-admin.ts",
    "check:admin": "npx tsx scripts/check-admin.ts",
    "set:system-owner": "npx tsx scripts/set-system-owner.ts",
    "dev": "next dev -H 127.0.0.1",
    "build": "unset npm_config_devdir && next build",
    "start": "next start",
    "start:3001": "next start -p 3001",
    "build:export": "next build",
    "deploy": "unset npm_config_devdir && npm run build && firebase deploy --only hosting,firestore:rules",
    "push": "git add . && (git diff --cached --quiet || git commit -m 'עדכון') && git push",
    "lint": "unset npm_config_devdir && eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "unset npm_config_devdir && tsc --noEmit",
    "verify": "npm run typecheck && npm run lint"
  },
